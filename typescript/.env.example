# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Your details -------------------------------------------------------------
USER_NAME=Jane Doe
USER_EMAIL=you@example.com

# Comma-separated topics, in priority order. Used by the agent to rank/dedupe
# at digest time. Be specific.
USER_INTERESTS=AI agents, growth marketing, dev tooling, startup funding


# --- Digest schedule ----------------------------------------------------------
# 24h format, local time.
DIGEST_TIME=08:00

# Optional: pin a username for the inbox (default: random)
# INBOX_USERNAME=newsletters


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=30
