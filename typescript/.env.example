# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Identity / routing -------------------------------------------------------
USER_NAME=Your Name
USER_EMAIL=you@example.com

# Optional: comma-separated list of preferred tag vocabulary. Claude will
# prefer these tags when relevant, and infer new ones when none fit.
PREFERRED_TAGS=work,personal,family,finance,health,reading


# --- Behavior -----------------------------------------------------------------
# Email action-item assignees directly with their task? Default false — most
# users want the agent to surface action items to themselves first, then
# decide what to forward. Flip to true if you trust the agent to ping
# colleagues on your behalf.
NOTIFY_ASSIGNEES=false

# Friday weekly digest hour (24h, local timezone)
DIGEST_HOUR=17
# Friday is weekday 4 (Mon=0). Set to 0-6 to change the day, or -1 to disable.
DIGEST_WEEKDAY=4

# Hours-before-deadline to fire reminder
REMINDER_HOURS=24


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=15

# Optional: pin a username for the inbox
# INBOX_USERNAME=notes
