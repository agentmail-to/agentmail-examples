# --- API keys -----------------------------------------------------------------
# AgentMail key — https://console.agentmail.to
AGENTMAIL_API_KEY=am_us_...

# Anthropic key — https://console.anthropic.com (used to extract OTP/link from
# messy verification emails when the regex fallback misses).
ANTHROPIC_API_KEY=sk-ant-...


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
# Run headless for CI / servers; false (headed) for local debugging
HEADLESS=false
