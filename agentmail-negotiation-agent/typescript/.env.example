# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Buyer (you) --------------------------------------------------------------
# The agent only accepts strategy replies from this address. Round summaries
# are sent here. Counterparties never see this address.
BUYER_EMAIL=you@example.com


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=30

# Optional: pin a username for the inbox
# INBOX_USERNAME=negotiator
