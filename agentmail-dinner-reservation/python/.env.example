# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Your details -------------------------------------------------------------
USER_NAME=Jane Doe
# The email you'll be sending reservation requests FROM. The agent only
# accepts requests from this address.
USER_EMAIL=you@example.com

# Used when the agent generates the .ics calendar invite. e.g.
# "America/Los_Angeles" → 7pm becomes -07:00 (PDT) in May, -08:00 (PST) in January.
TIMEZONE=America/Los_Angeles

# Optional: pin a specific username for the inbox (default: random)
# INBOX_USERNAME=reservations


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=15
