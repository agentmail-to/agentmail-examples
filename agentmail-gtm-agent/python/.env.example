# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Sender identity ----------------------------------------------------------
# Used in the cold-email writer prompt + signoff.
SENDER_NAME=Jane Doe
SENDER_ROLE=Founder
SENDER_COMPANY=Acme
# Optional extra signoff line (e.g., calendar link). Wrap multi-line in quotes.
# SENDER_SIGNOFF_EXTRA="P.S. Book a 15-min: https://cal.com/jane"
SENDER_SIGNOFF_EXTRA=


# --- Sales team handoff -------------------------------------------------------
# Where INTERESTED replies get forwarded with a handoff cover note.
SALES_EMAIL=sales@yourcompany.com


# --- Cadence ------------------------------------------------------------------
# Send the single follow-up this many hours after the first touch.
# Default 96 (4 days), per the brief. Set to 24-72 for tighter cadence.
FOLLOWUP_AFTER_HOURS=96


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=30

# Optional: pin a username for the inbox (default: random)
# INBOX_USERNAME=outreach
