# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Your details -------------------------------------------------------------
USER_NAME=Jane Doe
# The email you'll be sending reservation requests FROM. The agent only
# accepts requests from this address.
USER_EMAIL=you@example.com

# Used by Claude when generating the .ics calendar invite (so 7pm becomes the
# correct UTC offset for your zone, not a wrong-coast guess).
TIMEZONE=America/Los_Angeles

# Optional: pin a username for the inbox (default: random)
# INBOX_USERNAME=reservations


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=15
