# --- API keys -----------------------------------------------------------------
# AgentMail key — https://console.agentmail.to
AGENTMAIL_API_KEY=am_us_...

# Anthropic key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...


# --- Identity -----------------------------------------------------------------
PRODUCT_NAME=AgentMail
AGENT_NAME=Sam
# Where to forward tickets the agent can't resolve. Original email is forwarded
# with classification + reason in the cover note.
ESCALATION_EMAIL=support@yourcompany.com

# Optional: also let the agent search a public help center via Claude's
# web_search tool (in addition to knowledge_base.md). Leave blank to skip.
HELP_CENTER_URL=https://docs.agentmail.to

# Optional: pin a specific username for the inbox (default: random)
# INBOX_USERNAME=support


# --- Follow-up tuning ---------------------------------------------------------
# Send a "still working on this" update if a ticket has been escalated for this
# many hours with no closure.
FOLLOWUP_AFTER_HOURS=48
# Don't send another follow-up on the same ticket more often than this.
FOLLOWUP_COOLDOWN_HOURS=24


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=10
