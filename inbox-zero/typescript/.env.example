# --- API keys -----------------------------------------------------------------
# AgentMail key — https://console.agentmail.to
AGENTMAIL_API_KEY=am_us_...

# Anthropic key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...


# --- Your details -------------------------------------------------------------
USER_NAME=Jane Doe
USER_EMAIL=you@example.com
TIMEZONE=America/Los_Angeles

# Optional: pin a specific username for your inbox (default: random)
# INBOX_USERNAME=jane-inbox-zero


# --- Style matching -----------------------------------------------------------
# Paste 1-3 paragraphs of your own writing here. The agent will match this tone
# when drafting replies. Real examples > generic instructions.
# IMPORTANT: wrap multi-line values in double quotes so dotenv parses correctly.
STYLE_EXAMPLES="Hey — yep, that works. Let's do Tuesday at 3pm PT, I'll send the calendar invite.

Quick question on the deck: are you locked into the Friday deadline, or is there flex if we want to add the customer quotes in section 3?

Took a look — the data looks right. One small ask: can you split the revenue chart by region so we can see the West Coast jump? Otherwise good to go."


# --- Digest -------------------------------------------------------------------
# When to send the morning digest of overnight drafts. 24h format, local time.
WAKE_TIME=08:00


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=20
