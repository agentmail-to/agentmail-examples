# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Identity / routing -------------------------------------------------------
COMPANY_NAME=Acme
USER_EMAIL=you@example.com
FINANCE_EMAIL=finance@yourcompany.com


# --- Payment adapter ----------------------------------------------------------
# Which adapter handles the actual money movement.
#   mock     — built-in simulator that runs the full x402 wire shape (402 →
#              payment-proof → 200) against an in-memory test endpoint. Default.
#              Use this to demo the architecture without wiring real funds.
#   coinbase — Coinbase CDP x402 facilitator (Base Sepolia testnet or mainnet).
#              Requires CDP_API_KEY + WALLET_ADDRESS below. See coinbase_adapter.py.
PAYMENT_ADAPTER=mock

# Required only for PAYMENT_ADAPTER=coinbase
CDP_API_KEY=
CDP_API_SECRET=
WALLET_ADDRESS=
PAYMENT_NETWORK=base-sepolia


# --- Routing rules ------------------------------------------------------------
# Hard cap — payments above this require explicit user approval, regardless of
# the per-vendor limit in vendors.csv. Currency is whatever PAYMENT_CURRENCY is.
GLOBAL_MAX_USD=1000
PAYMENT_CURRENCY=USDC


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=15

# Optional: pin a username for the inbox
# INBOX_USERNAME=pay
