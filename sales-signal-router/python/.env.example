# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Slack --------------------------------------------------------------------
# REQUIRED: default webhook for any signal that doesn't match a per-flow override
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Optional per-flow overrides (fall back to SLACK_WEBHOOK_URL if blank)
SLACK_WEBHOOK_HOT=
SLACK_WEBHOOK_ENTERPRISE=
SLACK_WEBHOOK_DIGEST=


# --- Identity / routing -------------------------------------------------------
COMPANY_NAME=Acme
# Where the EOD digest gets emailed
SALES_LEAD_EMAIL=sales-lead@yourcompany.com


# --- Routing rules ------------------------------------------------------------
# Deal-size thresholds (USD; non-USD is converted at hardcoded rates below)
ENTERPRISE_THRESHOLD=100000
MID_MARKET_THRESHOLD=10000

# Send the EOD digest at this hour (24h, local timezone)
DIGEST_HOUR=17


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=15

# Optional: pin a username for the inbox
# INBOX_USERNAME=signals
