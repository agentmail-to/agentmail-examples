# --- API keys -----------------------------------------------------------------
AGENTMAIL_API_KEY=am_us_...
ANTHROPIC_API_KEY=sk-ant-...


# --- Identity -----------------------------------------------------------------
COMPANY_NAME=Acme Inc
# Where to forward invoices that need human review (no PO match, over the
# auto-approve limit, etc.). Original invoice + cover note both attached.
AP_EMAIL=ap@yourcompany.com


# --- Routing thresholds -------------------------------------------------------
# Invoices at or below this amount AND with a matching open PO get
# auto-approved. Anything else escalates to AP_EMAIL.
AUTO_APPROVE_LIMIT=5000

# Mark invoices urgent if due within this many days from today.
URGENT_DAYS=3


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=30

# Optional: pin a username for the inbox
# INBOX_USERNAME=ap
