# --- API keys -----------------------------------------------------------------
# AgentMail key — https://console.agentmail.to
AGENTMAIL_API_KEY=am_us_...

# Anthropic key — https://console.anthropic.com
# (Browser Use auto-reads ANTHROPIC_API_KEY when you use ChatAnthropic.)
ANTHROPIC_API_KEY=sk-ant-...


# --- The task -----------------------------------------------------------------
# What you want the agent to do. The agent has two AgentMail-backed tools
# available — `get_email_address` (returns the inbox address) and
# `get_latest_email` (fetches verification mail). Reference them by name in
# the task and the agent will use them at the right moments.
TASK=Go to https://news.ycombinator.com/login and create a new Hacker News account. Use get_email_address for the email field. Make up a username and password. After submitting, if a verification email is sent, call get_latest_email to retrieve the link, then click it. When done, summarize the credentials you used.


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
# How long get_latest_email waits on the websocket if no unread mail exists yet
EMAIL_TIMEOUT_SECONDS=120
# Run headless for CI / servers; false (headed) for local debugging
HEADLESS=false
