# --- API keys -----------------------------------------------------------------
# AgentMail key — https://console.agentmail.to
AGENTMAIL_API_KEY=am_us_...

# Anthropic key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...


# --- Your details -------------------------------------------------------------
USER_NAME=Jane Doe
USER_EMAIL=you@example.com

# What you want surfaced first — comma-separated topics. The agent uses this
# to rank/dedupe items at digest time. Be specific: "AI agents, growth-loop
# experiments, B2B pricing, dev tooling" beats "tech news".
USER_INTERESTS=AI agents, growth marketing, dev tooling, startup funding


# --- Digest schedule ----------------------------------------------------------
# 24h format, local time. Default 08:00.
DIGEST_TIME=08:00

# Optional: pin a specific username for the inbox (default: random)
# INBOX_USERNAME=newsletters


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=30
