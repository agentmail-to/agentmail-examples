# --- API keys -----------------------------------------------------------------
# AgentMail key — https://console.agentmail.to
AGENTMAIL_API_KEY=am_us_...

# Anthropic key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...


# --- What docs to answer from -------------------------------------------------
PRODUCT_NAME=AgentMail

# Full URL to your docs site. Used as both the search domain and as context
# in the system prompt. Example: https://docs.agentmail.to
DOCS_URL=https://docs.agentmail.to

# Where to forward questions the agent can't answer. The original email is
# forwarded with full context, plus a one-line note from the agent on what was searched.
ESCALATION_EMAIL=support@yourcompany.com

# Optional: pin a specific username for your inbox (default: random)
# INBOX_USERNAME=docs-help


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=10
# Cap on web searches per question. Higher = more thorough, more cost. Default 5.
MAX_SEARCHES_PER_QUESTION=5
