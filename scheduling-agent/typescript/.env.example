# --- API keys -----------------------------------------------------------------
# AgentMail key — https://console.agentmail.to
AGENTMAIL_API_KEY=am_us_...

# Anthropic key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...


# --- Your details -------------------------------------------------------------
USER_NAME=Jane Doe
USER_EMAIL=you@example.com
TIMEZONE=America/Los_Angeles

# Optional: pin a specific username for your inbox (default: random)
# INBOX_USERNAME=jane-scheduler


# --- Scheduling rules ---------------------------------------------------------
SALES_DAYS=Monday, Wednesday
SALES_HOURS=10am-4pm
INTERNAL_DAYS=Tuesday, Thursday
INTERNAL_HOURS=9am-5pm
PERSONAL_DAYS=Friday
BLOCKED_DAYS=Saturday, Sunday
MAX_CALLS_PER_DAY=4
BUFFER_MINUTES=15


# --- Tuning -------------------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6
POLL_INTERVAL_SECONDS=10
